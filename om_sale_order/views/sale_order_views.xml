<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_inherited" model="ir.ui.view">
        <field name="name">sale.order.form.inherited</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
                <xpath expr="//header" position="inside">

                    <button name="action_send_for_approval" string="Send for Approval" type="object" class="btn-primary" invisible="approval_status != 'pending' or state in ('sale', 'done', 'cancel')"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary"
                            groups="om_sale_order.group_sale_order_approver"
                            invisible="approval_status != 'waiting'"/>
                    <button name="action_reject" string="Reject" type="object"
                            groups="om_sale_order.group_sale_order_approver"
                            invisible="approval_status != 'waiting'"/>

                    <field name="approval_status" widget="statusbar" statusbar_visible="pending,waiting,approved,rejected" readonly="1"/>
                </xpath>


                <xpath expr="//button[@id='action_confirm']" position="attributes">
                    <attribute name="invisible">approval_status != 'approved' or state != 'sent'</attribute>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="after">
                    <field name="location_id"/>
                </xpath>

                <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                    <attribute name="invisible">approval_status != 'approved' or state != 'draft'</attribute>
                </xpath>

            </field>
        </record>

        <record id="sale_order_tree_inherited" model="ir.ui.view">
            <field name="name">sale.order.tree.inherited</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_order']" position="after">
                    <field name="location_id"/>
                    <field name="approval_status" readonly="1"/>
                </xpath>
            </field>
        </record>

        <record id="view_sale_order_search_inherit_location" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.location</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">


                <filter name="group_by_location"
                        string="Location"
                        context="{'group_by': 'location_id'}"/>

            </xpath>

        </field>
    </record>

        <record id="action_new_sales_orders" model="ir.actions.act_window">
            <field name="name">Orders</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">tree,form</field>
        </record>


        <record id="action_sale_order_approvals" model="ir.actions.act_window">
            <field name="name">Order Approvals</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('approval_status', '=', 'waiting')]</field>
        </record>
</odoo>