<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_employee_management" model="ir.actions.act_window">
        <field name="name">Employee</field>
        <field name="res_model">employee.management</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

    <record id="view_employee_management_tree" model="ir.ui.view">
        <field name="name">employee.management.tree</field>
        <field name="model">employee.management</field>
        <field name="arch" type="xml">
            <tree>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="work_address"/>
                <field name="work_email"/>
                <field name="work_phone"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <record id="view_employee_management_form" model="ir.ui.view">
        <field name="name">employee.management.form</field>
        <field name="model">employee.management</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Employee Info" name="Employee Info">
                            <field name="employee_id"/>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group string="Work Info" name="Work Info">
                            <field name="work_address"/>
                            <field name="work_email"/>
                            <field name="work_phone"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="private_info" string="Private Info">
                            <group>
                                <field name="private_address"/>
                                <field name="private_email"/>
                                <field name="private_phone"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_management_kanban" model="ir.ui.view">
        <field name="name">employee.management.kanban</field>
        <field name="model">employee.management</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="job_id"/>
                <field name="work_email"/>
                <field name="work_phone"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div><field name="job_id"/></div>
                                <div t-if="record.work_email.value">
                                    <i class="fa fa-envelope" aria-label="Email" title="Email"></i> <field name="work_email"/>
                                </div>
                                <div t-if="record.work_phone.value">
                                    <i class="fa fa-phone" aria-label="Phone" title="Phone"></i> <field name="work_phone"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>