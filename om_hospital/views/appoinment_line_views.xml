<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hospital_appoinment_line_tree" model="ir.ui.view" >
            <field name="name">hospital.appoinment.line.tree</field>
            <field name="model">hospital.appoinment.line</field>
            <field name="arch" type="xml">
                <tree string="Appoinment Lines" editable="top">
                    <field name="appoinment_id"/>
                    <field name="product_id"/>
                    <field name="qty"/>
                </tree>
            </field>
    </record>

      <record id="action_hospital_appoinment_line" model="ir.actions.act_window">
        <field name="name">Appoinment Line</field>
        <field name="res_model">hospital.appoinment.line</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new appoinment line
            </p>
        </field>
    </record>

</odoo>